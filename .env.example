# Copy this file to .env.local. Never commit the real file.
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5-mini

# Demo mode runs entirely from local fixtures. Use "live" after DataHub is connected.
DATAHUB_MODE=demo
DATAHUB_MCP_URL=https://your-tenant.acryl.io/integrations/ai/mcp
DATAHUB_TOKEN=replace_me
# Use a real dataset URN from the trial's sample catalog, or leave blank and let search choose.
DATAHUB_TEST_DATASET_URN=

# Mutation tools must also be enabled on the DataHub MCP server.
DATAHUB_ENABLE_WRITEBACK=false
